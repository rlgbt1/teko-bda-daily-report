# ─────────────────────────────────────────────────────────────────────────────
# Teko BDA Daily Report — environment variables
# Copy this file to `.env` and fill in the values.
# `.env` is git-ignored; never commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/
# Leave blank to disable AI summaries (report still generates without them).
GEMINI_API_KEY=

# ── Optional: override default model ─────────────────────────────────────────
# GEMINI_MODEL=gemini-2.0-flash

# ── Scraper URL overrides (optional — defaults are fine for most deployments) ─
# BODIVA_HOME_URL=https://www.bodiva.ao
# BODIVA_MARKET_URL=https://www.bodiva.ao/mercado
# BNA_HOME_URL=https://www.bna.ao

# ── Timeouts ─────────────────────────────────────────────────────────────────
# REQUEST_TIMEOUT=30
# MAX_RETRIES=3
